# ──────────────────────────────────────────────
# Sales Insight Automator – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────

# Groq AI API Key (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Resend Email API Key (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here

# Sender email address (must be verified in Resend)
EMAIL_FROM=onboarding@resend.dev

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Backend API URL (used by the frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
